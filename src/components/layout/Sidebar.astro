---
export interface Props {
  sections: { id: string; label: string; level?: 'beginner' | 'deep' | 'advanced' }[]
}

const { sections } = Astro.props
---

<aside class="w-64 shrink-0 hidden lg:block">
  <nav class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-4">
    <ul class="space-y-1">
      {
        sections.map((section) => (
          <li>
            <a
              href={`#${section.id}`}
              class="block px-3 py-1.5 text-sm text-neutral-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors"
            >
              {section.level === 'beginner' ? '🟢 ' : section.level === 'deep' ? '🟡 ' : section.level === 'advanced' ? '🔬 ' : ''}
              {section.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
