---
import { SITE } from '../../consts'
---

<footer class="border-t border-neutral-200 bg-neutral-50 mt-16">
  <div class="max-w-page mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-neutral-500">
      <p>© {new Date().getFullYear()} {SITE.author}</p>
      <p class="text-center">
        Hecho para entender — no para memorizar.
        <span class="block sm:inline sm:ml-1">Contribuciones bienvenidas.</span>
      </p>
      <a href="https://github.com/javierpa95/llm" class="hover:text-primary-600 transition-colors" target="_blank">
        GitHub →
      </a>
    </div>
  </div>
</footer>
