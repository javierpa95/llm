---
export interface Props {
  title: string
  description?: string
  url?: string
  compact?: boolean
}

const { title, description = '', url = Astro.url.toString(), compact = false } = Astro.props
const encodedUrl = encodeURIComponent(url)
const encodedTitle = encodeURIComponent(title)
const shareText = `${title}\n${url}`
---

<div class:list={['share-buttons', compact && 'share-compact']}>
  {!compact && <span class="share-label">Compartir</span>}
  <div class="share-grid">
    <!-- X (Twitter) -->
    <a
      href={`https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn share-x"
      aria-label="Compartir en X"
      data-share-text={`${title}\n${url}`}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      <span class="share-btn-label">X</span>
    </a>

    <!-- LinkedIn -->
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn share-linkedin"
      aria-label="Compartir en LinkedIn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      <span class="share-btn-label">LinkedIn</span>
    </a>

    <!-- WhatsApp -->
    <a
      href={`https://wa.me/?text=${encodedTitle}%20${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn share-whatsapp"
      aria-label="Compartir en WhatsApp"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="share-btn-label">WhatsApp</span>
    </a>

    <!-- Copiar enlace (JS, sin escaped quotes rotas) -->
    <button
      class="share-btn share-copy"
      aria-label="Copiar enlace"
      id="share-copy-btn"
      data-copy-url={url}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
      </svg>
      <span class="share-btn-label">Copiar</span>
    </button>
  </div>
</div>

<script>
  // Botón Copiar
  document.querySelectorAll('.share-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-copy-url')
      if (!url) return
      try {
        await navigator.clipboard.writeText(url)
        const label = btn.querySelector('.share-btn-label')
        if (label) {
          const original = label.textContent
          label.textContent = '✓ Copiado'
          setTimeout(() => { label.textContent = original }, 2000)
        }
      } catch (e) {
        const textarea = document.createElement('textarea')
        textarea.value = url
        document.body.appendChild(textarea)
        textarea.select()
        document.execCommand('copy')
        document.body.removeChild(textarea)
      }
    })
  })

  // X: en móvil, intentar URL scheme nativo primero
  if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    document.querySelector('.share-x')?.addEventListener('click', function(e) {
      const text = this.getAttribute('data-share-text') || ''
      const webUrl = this.getAttribute('href')
      if (!text) return

      e.preventDefault()

      // Intentar abrir la app vía URL scheme nativo
      // twitter://post?message= funciona en iOS y Android para abrir compose precargado
      const nativeUrl = 'twitter://post?message=' + encodeURIComponent(text)
      
      // Intentar app nativa
      window.location.href = nativeUrl

      // Fallback a web si no abre la app (tras 1.5s)
      setTimeout(() => {
        window.location.href = webUrl
      }, 1500)

      // Si la app se abre (la página se oculta), cancelar fallback
      const onVisibility = () => {
        if (document.hidden) {
          // La app se abrió, cancelar timeout
          const timerId = setTimeout(() => {}, 0)
          for (let i = 0; i <= timerId; i++) clearTimeout(i)
          document.removeEventListener('visibilitychange', onVisibility)
        }
      }
      document.addEventListener('visibilitychange', onVisibility)
    })
  }
</script>

<style>
  .share-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .share-compact {
    flex-direction: row;
    align-items: center;
  }
  .share-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #a3a3a3;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .share-compact .share-label {
    margin-right: 0.25rem;
  }
  .share-grid {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 1px solid #e5e5e5;
    background: #fff;
    color: #404040;
    cursor: pointer;
    transition: all 0.15s ease;
    text-decoration: none;
    line-height: 1;
  }
  .share-btn:hover {
    border-color: #c7d2fe;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.08);
    transform: translateY(-1px);
  }
  .share-btn-label {
    font-size: 0.75rem;
  }
  .share-x:hover { color: #000; border-color: #000; }
  .share-linkedin:hover { color: #0a66c2; border-color: #0a66c2; }
  .share-whatsapp:hover { color: #25d366; border-color: #25d366; }
  .share-copy:hover { color: #4f46e5; border-color: #4f46e5; }

  /* Compact variant */
  .share-compact .share-btn {
    padding: 0.375rem 0.5rem;
  }
  .share-compact .share-btn svg {
    width: 16px;
    height: 16px;
  }
  .share-compact .share-btn-label {
    display: none;
  }
</style>
