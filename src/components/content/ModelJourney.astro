---
// ModelJourney.astro — Animación del viaje completo del modelo
// 3 fases: Carga → Forward Pass → Generación autoregresiva
// Muestra cómo los pesos viajan del disco a VRAM, cómo el texto se procesa,
// y por qué cada token nuevo requiere releer todo desde VRAM.
---

<div class="model-journey" id="model-journey">
  <h3 class="text-lg font-semibold text-neutral-900 mb-2 text-center">🚀 El viaje completo del modelo</h3>
  <p class="text-sm text-neutral-600 mb-4 text-center">
    Sigue el recorrido de los datos desde que el modelo está en disco hasta que se genera cada nueva palabra.
  </p>

  <!-- === CONTROL DE FASE (tabs) === -->
  <div class="flex gap-1 mb-6 bg-neutral-100 rounded-xl p-1" role="tablist">
    <button class="phase-btn flex-1 px-3 py-2 text-sm font-medium rounded-lg transition-all" data-phase="0" data-active="true" role="tab" aria-selected="true">
      1️⃣ Cargar modelo
    </button>
    <button class="phase-btn flex-1 px-3 py-2 text-sm font-medium rounded-lg transition-all" data-phase="1" data-active="false" role="tab" aria-selected="false">
      2️⃣ Procesar texto
    </button>
    <button class="phase-btn flex-1 px-3 py-2 text-sm font-medium rounded-lg transition-all" data-phase="2" data-active="false" role="tab" aria-selected="false">
      3️⃣ Generar tokens
    </button>
  </div>

  <!-- === BOTÓN DE CONTROL === -->
  <div class="text-center mb-4">
    <button id="play-btn" class="inline-flex items-center gap-2 px-5 py-2 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition-colors">
      ▶️ Iniciar animación
    </button>
    <button id="reset-btn" class="inline-flex items-center gap-2 px-3 py-2 bg-neutral-200 text-neutral-600 text-sm rounded-xl hover:bg-neutral-300 transition-colors ml-2">
      ↺ Reiniciar
    </button>
  </div>

  <!-- === VISUALIZACIÓN PRINCIPAL === -->
  <div class="relative bg-white border border-neutral-200 rounded-2xl p-4 sm:p-6 mb-4 overflow-hidden" style="min-height: 360px;">
    <!-- SVG fondo estático -->
    <svg class="w-full h-auto" viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg" style="max-width: 100%;">
      
      <!-- === SSD / Disco === -->
      <rect x="20" y="100" width="120" height="120" rx="10" fill="#1e293b" stroke="#0f172a" stroke-width="2"/>
      <text x="80" y="145" text-anchor="middle" font-size="12" fill="#e2e8f0" font-weight="bold" font-family="system-ui">SSD</text>
      <text x="80" y="163" text-anchor="middle" font-size="9" fill="#94a3b8" font-family="system-ui">Disco</text>
      <text x="80" y="180" text-anchor="middle" font-size="8" fill="#64748b" font-family="system-ui">~7 GB/s</text>
      <!-- Icono de disco -->
      <circle cx="80" cy="120" r="10" fill="none" stroke="#64748b" stroke-width="1.5"/>
      <circle cx="80" cy="120" r="4" fill="#64748b"/>

      <!-- Flecha SSD → GPU -->
      <line x1="140" y1="160" x2="250" y2="160" stroke="#f59e0b" stroke-width="2" stroke-dasharray="6,3" class="bus-line"/>
      <text x="195" y="150" text-anchor="middle" font-size="8" fill="#d97706" font-family="system-ui">PCIe 4.0</text>
      <text x="195" y="175" text-anchor="middle" font-size="7" fill="#d97706" font-family="system-ui">~32 GB/s</text>

      <!-- === GPU Chip === -->
      <rect x="260" y="60" width="280" height="200" rx="12" fill="#1e293b" stroke="#0f172a" stroke-width="2"/>
      <text x="400" y="85" text-anchor="middle" font-size="12" fill="#e2e8f0" font-weight="bold" font-family="system-ui">GPU Chip</text>
      <text x="400" y="100" text-anchor="middle" font-size="8" fill="#94a3b8" font-family="system-ui">~3 cm × 3 cm, 2.23 GHz</text>

      <!-- SM blocks dentro de la GPU -->
      <g id="sm-group">
        <rect x="275" y="115" width="36" height="40" rx="3" fill="#10b981" opacity="0.7"/>
        <text x="293" y="139" text-anchor="middle" font-size="6" fill="white" font-family="system-ui">SM</text>
        <rect x="318" y="115" width="36" height="40" rx="3" fill="#10b981" opacity="0.7"/>
        <rect x="361" y="115" width="36" height="40" rx="3" fill="#10b981" opacity="0.7"/>
        <rect x="404" y="115" width="36" height="40" rx="3" fill="#10b981" opacity="0.7"/>
        <rect x="447" y="115" width="36" height="40" rx="3" fill="#10b981" opacity="0.7"/>
        <text x="293" y="156" text-anchor="middle" font-size="5" fill="#a7f3d0" font-family="system-ui">×128</text>
        <text x="293" y="163" text-anchor="middle" font-size="5" fill="#a7f3d0" font-family="system-ui">L1: 16 MB</text>
      </g>

      <!-- L2 Cache -->
      <rect x="275" y="170" width="210" height="12" rx="3" fill="#3b82f6" opacity="0.6"/>
      <text x="380" y="179" text-anchor="middle" font-size="6" fill="#bfdbfe" font-family="system-ui">L2 Cache — 72 MB</text>

      <!-- Tensor Core highlight -->
      <rect x="275" y="190" width="210" height="16" rx="3" fill="#8b5cf6" opacity="0.5"/>
      <text x="380" y="202" text-anchor="middle" font-size="6" fill="#ddd6fe" font-family="system-ui">Tensor Cores — matmul 4×4 en 1 ciclo</text>

      <!-- Caja de texto "procesando" (aparece durante fase 2) -->
      <g id="text-box" opacity="0">
        <rect x="270" y="218" width="120" height="20" rx="4" fill="#fef3c7" stroke="#f59e0b" stroke-width="1"/>
        <text x="330" y="232" text-anchor="middle" font-size="7" fill="#92400e" font-family="system-ui" id="token-display">token</text>
      </g>

      <!-- === Bus GPU ↔ VRAM === -->
      <line x1="540" y1="100" x2="620" y2="100" stroke="#f59e0b" stroke-width="2.5" class="bus-line"/>
      <line x1="540" y1="140" x2="620" y2="140" stroke="#f59e0b" stroke-width="2.5" class="bus-line"/>
      <line x1="540" y1="180" x2="620" y2="180" stroke="#f59e0b" stroke-width="2.5" class="bus-line"/>
      <line x1="540" y1="220" x2="620" y2="220" stroke="#f59e0b" stroke-width="2.5" class="bus-line"/>
      <text x="580" y="93" text-anchor="middle" font-size="8" fill="#d97706" font-family="system-ui" font-weight="bold">Bus 384-bit</text>
      <text x="580" y="250" text-anchor="middle" font-size="7" fill="#d97706" font-family="system-ui">1008 GB/s</text>

      <!-- === VRAM === -->
      <rect x="630" y="50" width="150" height="220" rx="10" fill="#7c3aed" opacity="0.15" stroke="#7c3aed" stroke-width="2" stroke-dasharray="4,2"/>
      <text x="705" y="78" text-anchor="middle" font-size="11" fill="#6d28d9" font-weight="bold" font-family="system-ui">💾 VRAM</text>
      
      <!-- Chips de VRAM -->
      <rect x="643" y="90" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>
      <text x="670" y="108" text-anchor="middle" font-size="6" fill="#ddd6fe" font-family="system-ui">2 GB</text>
      <rect x="712" y="90" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>

      <rect x="643" y="128" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>
      <rect x="712" y="128" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>

      <rect x="643" y="166" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>
      <rect x="712" y="166" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>

      <rect x="643" y="204" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>
      <rect x="712" y="204" width="55" height="28" rx="4" fill="#7c3aed" opacity="0.5" class="vram-chip"/>

      <text x="705" y="248" text-anchor="middle" font-size="7" fill="#6d28d9" font-family="system-ui">12 chips × 2 GB = 24 GB</text>

      <!-- Texto modelo cargado en VRAM -->
      <text x="705" y="268" text-anchor="middle" font-size="8" fill="#6d28d9" font-family="system-ui" font-weight="bold" id="vram-status">Esperando...</text>

      <!-- === Partículas animadas (se generan desde JS) === -->
      <g id="particles-layer"></g>
    </svg>

    <!-- Overlay de información durante la animación -->
    <div id="info-overlay" class="absolute top-2 right-2 bg-white/95 border border-neutral-200 rounded-xl p-3 shadow-lg text-xs space-y-1 max-w-[200px] hidden">
      <p class="font-semibold text-neutral-800" id="phase-title">Fase 1: Carga</p>
      <p class="text-neutral-600" id="info-line-1">Preparando...</p>
      <p class="text-neutral-600" id="info-line-2"></p>
      <p class="text-neutral-500" id="info-line-3"></p>
    </div>

    <!-- Barra de progreso para carga -->
    <div class="mt-2 hidden" id="progress-bar-container">
      <div class="flex items-center justify-between text-xs text-neutral-500 mb-1">
        <span id="progress-label">Cargando modelo...</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="w-full h-2.5 bg-neutral-200 rounded-full overflow-hidden">
        <div id="progress-fill" class="h-full bg-gradient-to-r from-purple-500 to-blue-500 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Área de output de texto generado -->
    <div id="text-output" class="mt-3 p-3 bg-neutral-50 rounded-xl border border-neutral-200 hidden">
      <div class="flex items-center gap-2 text-xs text-neutral-500 mb-1">
        <span>📝 Texto generado:</span>
      </div>
      <div class="flex flex-wrap gap-1" id="generated-tokens">
        <span class="px-2 py-0.5 bg-blue-100 text-blue-700 rounded text-sm" id="input-prompt">La capital de Francia es</span>
        <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-sm font-bold" id="output-token"></span>
        <span class="px-2 py-0.5 text-neutral-300 rounded text-sm" id="token-cursor">|</span>
      </div>
    </div>
  </div>

  <!-- === PANEL INFERIOR: EXPLICACIÓN DE LA FASE === -->
  <div class="p-4 bg-neutral-50 border border-neutral-200 rounded-xl">
    <div id="phase-explanation">
      <p class="text-sm text-neutral-700">
        <strong>🔵 Fase 1: Cargar modelo</strong> — Los pesos (parámetros) viajan desde el SSD a la VRAM a través del PCIe. 
        Un modelo de 7B en FP16 pesa ~14 GB. Tarda unos segundos en cargarse completamente.
        Una vez en VRAM, los pesos están listos para ser leídos por la GPU.
      </p>
    </div>
    <div class="mt-3 flex items-center gap-2 text-xs text-neutral-400" id="data-counter">
      <span>📊 Datos transferidos: <strong id="total-data" class="text-neutral-700">0 GB</strong></span>
      <span class="mx-1">|</span>
      <span>Tokens generados: <strong id="token-count" class="text-neutral-700">0</strong></span>
      <span class="mx-1">|</span>
      <span>🌐 <a href="/fundamentos" class="text-primary-600 hover:underline">Calculadora VRAM</a></span>
    </div>
  </div>
</div>

<style>
  .model-journey {
    user-select: none;
  }
  .phase-btn[data-active="true"] {
    @apply bg-white text-neutral-900 shadow-sm;
  }
  .phase-btn[data-active="false"] {
    @apply text-neutral-500 hover:text-neutral-700;
  }
  .bus-line {
    stroke-dasharray: 8 4;
    animation: busDash 1s linear infinite;
  }
  @keyframes busDash {
    to { stroke-dashoffset: -24; }
  }
  /* Partícula animada */
  .particle {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    pointer-events: none;
  }
  .particle-weight { background: #7c3aed; }  /* purple — pesos */
  .particle-token { background: #3b82f6; }   /* blue — tokens */
  .particle-result { background: #10b981; }   /* green — resultados */
  @keyframes float {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  @keyframes pulseGlow {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }
</style>

<script>
(function(){
  const container = document.getElementById('model-journey');
  const svg = container.querySelector('svg');
  const phaseBtns = container.querySelectorAll('.phase-btn');
  const playBtn = document.getElementById('play-btn');
  const resetBtn = document.getElementById('reset-btn');
  const infoOverlay = document.getElementById('info-overlay');
  const phaseTitle = document.getElementById('phase-title');
  const infoLine1 = document.getElementById('info-line-1');
  const infoLine2 = document.getElementById('info-line-2');
  const infoLine3 = document.getElementById('info-line-3');
  const progressContainer = document.getElementById('progress-bar-container');
  const progressFill = document.getElementById('progress-fill');
  const progressPct = document.getElementById('progress-pct');
  const progressLabel = document.getElementById('progress-label');
  const textOutput = document.getElementById('text-output');
  const outputToken = document.getElementById('output-token');
  const tokenCursor = document.getElementById('token-cursor');
  const totalData = document.getElementById('total-data');
  const tokenCount = document.getElementById('token-count');
  const vramStatus = document.getElementById('vram-status');
  const phaseExplanation = document.getElementById('phase-explanation');
  const particlesLayer = document.getElementById('particles-layer');
  const textBox = document.getElementById('text-box');
  const tokenDisplay = document.getElementById('token-display');

  let currentPhase = 0;
  let animating = false;
  let animationId = null;
  let particles = [];
  let phaseProgress = 0;

  // Palabras para generar
  const TOKENS = [' París', ' es', ' una', ' ciudad', ' hermosa', '.'];
  const INPUT_TEXT = 'La capital de Francia es';

  const PHASE_TITLES = [
    '📦 Cargando modelo a VRAM',
    '⚡ Procesando el texto',
    '🔄 Generando tokens (autoregresivo)'
  ];

  const PHASE_EXPLANATIONS = [
    '<strong>🔵 Fase 1: Cargar modelo</strong> — Los pesos (parámetros) viajan desde el SSD a la VRAM a través del PCIe. Un modelo de 7B en FP16 pesa ~14 GB. Tarda unos segundos en cargarse completamente. Una vez en VRAM, los pesos están listos para ser leídos por la GPU.',
    '<strong>🟢 Fase 2: Procesar texto</strong> — El texto de entrada se tokeniza y los tokens se cargan en la GPU. Cada capa del Transformer procesa los tokens: primero <strong>Atención</strong> (cada token mira a los demás), luego <strong>Feed-Forward</strong> (cada token procesa su información). Al final, la GPU predice la siguiente palabra: «París».',
    '<strong>🟠 Fase 3: Generar tokens</strong> — Esto es clave: <strong>cada nuevo token requiere releer todos los pesos desde VRAM</strong>. El modelo no recuerda nada entre tokens — cada predicción empieza desde cero, volviendo a cargar todas las matrices de pesos. Por eso la inferencia es <em>memory-bound</em>: la GPU se pasa el 99% del tiempo esperando a que los pesos lleguen desde VRAM.'
  ];

  function setPhase(phase) {
    currentPhase = phase;
    phaseBtns.forEach((btn, i) => {
      btn.setAttribute('data-active', String(i === phase));
      btn.setAttribute('aria-selected', String(i === phase));
    });
    infoOverlay.classList.add('hidden');
    progressContainer.classList.add('hidden');
    textOutput.classList.add('hidden');
    vramStatus.textContent = 'Esperando...';
    phaseProgress = 0;
    
    // Reset VRAM chips
    document.querySelectorAll('.vram-chip').forEach(el => {
      el.setAttribute('fill', '#7c3aed');
      el.setAttribute('opacity', '0.5');
    });

    // Reset text box
    textBox.setAttribute('opacity', '0');

    // Clear particles
    clearParticles();

    // Reset output
    outputToken.textContent = '';
    tokenCursor.style.display = 'inline';

    // Actualizar explicación
    phaseExplanation.innerHTML = PHASE_EXPLANATIONS[phase];
    
    // Reset data counter for phase 1
    if (phase === 0) {
      totalData.textContent = '0 GB';
      tokenCount.textContent = '0';
      phaseTitle.textContent = PHASE_TITLES[0];
    } else if (phase === 1) {
      totalData.textContent = '14 GB';
      phaseTitle.textContent = PHASE_TITLES[1];
    } else {
      totalData.textContent = '14 GB';
      tokenCount.textContent = '1';
      phaseTitle.textContent = PHASE_TITLES[2];
    }
  }

  function clearParticles() {
    particles.forEach(p => {
      if (p.element && p.element.parentNode) {
        p.element.parentNode.removeChild(p.element);
      }
    });
    particles = [];
  }

  function createParticle(cx, cy, color, label) {
    const ns = 'http://www.w3.org/2000/svg';
    const g = document.createElementNS(ns, 'g');
    const circle = document.createElementNS(ns, 'circle');
    circle.setAttribute('r', '4');
    circle.setAttribute('fill', color);
    circle.setAttribute('cx', '0');
    circle.setAttribute('cy', '0');
    g.appendChild(circle);
    
    if (label) {
      const text = document.createElementNS(ns, 'text');
      text.setAttribute('x', '0');
      text.setAttribute('y', '-6');
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('font-size', '4');
      text.setAttribute('fill', '#64748b');
      text.setAttribute('font-family', 'system-ui');
      text.textContent = label;
      g.appendChild(text);
    }
    
    g.setAttribute('transform', `translate(${cx}, ${cy})`);
    particlesLayer.appendChild(g);
    
    return {
      element: g,
      x: cx,
      y: cy,
      targetX: cx,
      targetY: cy,
      progress: 0,
      speed: 0.02 + Math.random() * 0.03,
      done: false
    };
  }

  function animateParticle(p, targetX, targetY) {
    p.targetX = targetX;
    p.targetY = targetY;
    p.progress = 0;
    p.done = false;
  }

  function updateParticles() {
    let allDone = true;
    particles.forEach(p => {
      if (!p.done) {
        p.progress += p.speed;
        if (p.progress >= 1) {
          p.progress = 1;
          p.done = true;
        }
        const ease = 1 - Math.pow(1 - p.progress, 3); // easeOutCubic
        const x = p.x + (p.targetX - p.x) * ease;
        const y = p.y + (p.targetY - p.y) * ease;
        p.element.setAttribute('transform', `translate(${x}, ${y})`);
        allDone = false;
      }
    });
    return allDone;
  }

  // === FASE 1: Cargar modelo ===
  function animatePhase1() {
    if (currentPhase !== 0) return;
    
    const numParticles = 60;
    const startX = 80; // SSD center
    const startY = 160;
    const vramCenters = [];
    
    for (let row = 0; row < 4; row++) {
      for (let col = 0; col < 2; col++) {
        vramCenters.push({
          x: 665 + col * 70,
          y: 104 + row * 38
        });
      }
    }

    // Create particles
    for (let i = 0; i < numParticles; i++) {
      const targetIdx = i % vramCenters.length;
      const p = createParticle(
        startX + (Math.random() - 0.5) * 40,
        startY + (Math.random() - 0.5) * 20,
        '#7c3aed'
      );
      p.delay = i * 0.015;
      p.vramIdx = targetIdx;
      p.targetPos = vramCenters[targetIdx];
      p.started = false;
      particles.push(p);
    }

    animating = true;
    infoOverlay.classList.remove('hidden');
    progressContainer.classList.remove('hidden');
    progressContainer.classList.remove('hidden');
    let elapsed = 0;
    let progress = 0;
    
    function step() {
      if (currentPhase !== 0) { animating = false; return; }
      
      elapsed += 0.016;
      progress = Math.min(elapsed / 4, 1); // 4 seconds
      
      progressFill.style.width = (progress * 100) + '%';
      progressPct.textContent = Math.round(progress * 100) + '%';
      
      if (progress < 0.5) {
        progressLabel.textContent = 'Cargando pesos del modelo...';
        infoLine1.textContent = '📦 Transfiriendo 14 GB desde SSD';
        infoLine2.textContent = `Progreso: ${Math.round(progress * 100)}%`;
        infoLine3.textContent = 'Velocidad: ~3.5 GB/s (PCIe 4.0)';
      } else {
        progressLabel.textContent = 'Distribuyendo en chips VRAM...';
        infoLine1.textContent = '🔀 Distribuyendo en 12 chips GDDR6X';
        infoLine2.textContent = `Completado: ${Math.round(progress * 100)}%`;
        infoLine3.textContent = 'Pesos listos para ser leídos por la GPU';
      }

      // Animate particles
      particles.forEach(p => {
        if (!p.started) {
          if (elapsed > p.delay) p.started = true;
          return;
        }
        if (!p.done) {
          const speed = 0.03 + (1 - progress) * 0.02;
          p.progress += speed;
          if (p.progress >= 1) {
            p.progress = 1;
            p.done = true;
          }
          const ease = 1 - Math.pow(1 - p.progress, 3);
          const x = startX + (p.targetPos.x - startX) * ease;
          const y = startY + (p.targetPos.y - startY) * ease;
          p.element.setAttribute('transform', `translate(${x}, ${y})`);
        }
      });

      // Light up VRAM chips as they fill
      const chipsToLight = Math.floor((progress / 0.85) * 8);
      document.querySelectorAll('.vram-chip').forEach((chip, i) => {
        if (i < chipsToLight) {
          chip.setAttribute('fill', '#7c3aed');
          chip.setAttribute('opacity', '0.85');
        } else {
          chip.setAttribute('fill', '#7c3aed');
          chip.setAttribute('opacity', '0.35');
        }
      });

      if (progress >= 1) {
        // Complete
        document.querySelectorAll('.vram-chip').forEach(chip => {
          chip.setAttribute('fill', '#7c3aed');
          chip.setAttribute('opacity', '0.9');
        });
        progressLabel.textContent = '✅ Modelo cargado en VRAM';
        progressPct.textContent = '100%';
        vramStatus.textContent = '✅ 14 GB cargados';
        infoLine1.textContent = '✅ Modelo 7B (FP16) cargado en VRAM';
        infoLine2.textContent = 'Pesos listos en 24 GB GDDR6X';
        infoLine3.textContent = '💡 Tiempo real: ~3-5 segundos';
        totalData.textContent = '14 GB';
        playBtn.textContent = '▶️ Siguiente fase: Procesar texto';
        playBtn.dataset.nextPhase = '1';
        animating = false;
        return;
      }

      animationId = requestAnimationFrame(step);
    }

    step();
  }

  // === FASE 2: Procesar texto ===
  function animatePhase2() {
    if (currentPhase !== 1) return;
    
    animating = true;
    infoOverlay.classList.remove('hidden');
    textOutput.classList.remove('hidden');
    textOutput.classList.remove('hidden');
    vramStatus.textContent = '⚡ Procesando...';
    progressContainer.classList.add('hidden');

    infoLine1.textContent = '📝 Tokenizando: "La capital de Francia es"';
    infoLine2.textContent = '→ [67, 456, 789, 12, 345] (5 tokens)';
    infoLine3.textContent = 'Cada token es un vector de 4096 números';

    // Mostrar texto de entrada
    const inputPrompt = document.getElementById('input-prompt');
    inputPrompt.textContent = '';

    // Animar escritura del prompt
    let charIdx = 0;
    const promptText = 'La capital de Francia es';
    function typePrompt() {
      if (currentPhase !== 1) { animating = false; return; }
      if (charIdx <= promptText.length) {
        inputPrompt.textContent = promptText.substring(0, charIdx);
        charIdx++;
        setTimeout(typePrompt, 80);
      } else {
        // Prompt escrito, ahora animar el procesamiento
        setTimeout(processThroughLayers, 500);
      }
    }

    function processThroughLayers() {
      if (currentPhase !== 1) { animating = false; return; }
      
      infoLine1.textContent = '⚡ Capa 1/32: Atención';
      infoLine2.textContent = 'Cada token mira a los demás tokens';
      infoLine3.textContent = 'Q, K, V se calculan → pesos de atención';

      // Activar text box en GPU
      textBox.setAttribute('opacity', '1');
      tokenDisplay.textContent = 'Tokenizing...';

      // Simular paso por capas
      let layer = 0;
      const totalLayers = 32;
      
      function processLayer() {
        if (currentPhase !== 1) { animating = false; return; }
        layer++;
        
        if (layer <= 32) {
          const phase = layer % 2 === 1 ? '🧠 Atención' : '⚙️ Feed-Forward';
          tokenDisplay.textContent = `Capa ${layer}: ${phase}`;
          
          if (layer % 2 === 1) {
            infoLine1.textContent = `⚡ Capa ${layer}/32: Atención`;
            infoLine2.textContent = 'Cada token pondera la importancia de los demás';
          } else {
            infoLine1.textContent = `⚡ Capa ${layer}/32: Feed-Forward`;
            infoLine2.textContent = 'Cada token procesa su información individualmente';
          }
          infoLine3.textContent = `Progreso: ${Math.round(layer/32*100)}%`;

          // Partículas de procesamiento dentro de la GPU
          if (layer % 4 === 0) {
            const p = createParticle(
              380 + (Math.random() - 0.5) * 80,
              130 + (Math.random() - 0.5) * 60,
              '#3b82f6',
              ''
            );
            p.progress = 1;
            p.done = true;
            setTimeout(() => {
              if (p.element.parentNode) p.element.parentNode.removeChild(p.element);
            }, 500);
          }

          setTimeout(processLayer, layer <= 4 ? 800 : 200);
        } else {
          // Todas las capas procesadas → predecir token
          infoLine1.textContent = '🎯 Prediciendo la siguiente palabra...';
          infoLine2.textContent = 'Distribución de probabilidad sobre 32,000 tokens';
          infoLine3.textContent = 'Token más probable: París (p=0.87)';

          tokenDisplay.textContent = 'Prediciendo...';
          
          setTimeout(() => {
            if (currentPhase !== 1) { animating = false; return; }
            // Mostrar el token generado
            outputToken.textContent = 'París';
            tokenCursor.style.display = 'none';
            
            // Glow effect on VRAM chips
            document.querySelectorAll('.vram-chip').forEach(chip => {
              chip.setAttribute('opacity', '0.9');
              setTimeout(() => {
                if (currentPhase === 1) {
                  chip.setAttribute('opacity', '0.6');
                }
              }, 600);
            });

            textBox.setAttribute('opacity', '0');
            
            infoLine1.textContent = '✅ Token generado: "París"';
            infoLine2.textContent = 'La GPU ha leído 13.4 GB de pesos de VRAM';
            infoLine3.textContent = '💡 Pero el proceso no termina aquí...';

            vramStatus.textContent = '✅ "París" generado';
            totalData.textContent = '27.4 GB';
            tokenCount.textContent = '1';
            
            playBtn.textContent = '▶️ Siguiente fase: Generar más tokens';
            playBtn.dataset.nextPhase = '2';
            animating = false;
          }, 800);
        }
      }

      setTimeout(processLayer, 300);
    }

    typePrompt();
  }

  // === FASE 3: Generación autoregresiva ===
  function animatePhase3() {
    if (currentPhase !== 2) return;
    
    animating = true;
    infoOverlay.classList.remove('hidden');
    textOutput.classList.remove('hidden');
    textOutput.classList.remove('hidden');
    vramStatus.textContent = '🔄 Generando...';
    progressContainer.classList.remove('hidden');
    progressContainer.classList.remove('hidden');
    progressFill.style.width = '0%';

    // Asegurar que el prompt está visible
    document.getElementById('input-prompt').textContent = 'La capital de Francia es';
    
    // Generar tokens uno por uno
    let tokenIdx = 0;
    let accumulatedData = 14; // already loaded
    
    // Agregar el primer token si ya se generó en fase 2
    outputToken.textContent = '';
    let generatedText = 'La capital de Francia es';
    
    function generateNext() {
      if (currentPhase !== 2) { animating = false; return; }
      
      if (tokenIdx >= TOKENS.length) {
        // Completado
        progressLabel.textContent = '✅ Generación completa';
        progressPct.textContent = '100%';
        infoLine1.textContent = '✅ Frase completa generada';
        infoLine2.textContent = `Total: ${TOKENS.length} tokens generados`;
        infoLine3.textContent = `📊 Datos totales transferidos: ${accumulatedData} GB`;
        vramStatus.textContent = `✅ ${TOKENS.length} tokens generados`;
        totalData.textContent = accumulatedData + ' GB';
        tokenCount.textContent = TOKENS.length + 1;
        playBtn.textContent = '▶️ Repetir desde el inicio';
        playBtn.dataset.nextPhase = '0';
        playBtn.onclick = function() { resetAll(); };
        animating = false;
        return;
      }

      const token = TOKENS[tokenIdx];
      const tokenNum = tokenIdx + 1;
      const readPerToken = 13.4;
      accumulatedData += readPerToken;
      
      // Actualizar info
      phaseTitle.textContent = `🔄 Generando token ${tokenNum}/${TOKENS.length}`;
      infoLine1.textContent = `📖 Leyendo todos los pesos desde VRAM (${Math.round(readPerToken)} GB)`;
      infoLine2.textContent = `Token "${token.trim()}" — viaje ${tokenNum}/${TOKENS.length}`;
      infoLine3.textContent = `🔁 Cada token requiere leer el modelo completo otra vez`;
      
      vramStatus.textContent = `🔄 Token ${tokenNum}: leyendo VRAM...`;
      progressLabel.textContent = `Generando token "${token.trim()}"...`;
      progressPct.textContent = `${Math.round((tokenNum / TOKENS.length) * 100)}%`;
      progressFill.style.width = `${(tokenNum / TOKENS.length) * 100}%`;

      // Animación de partículas: VRAM → GPU (pesos fluyendo)
      const numParticles = 20;
      for (let i = 0; i < numParticles; i++) {
        const fromX = 665 + Math.random() * 70;
        const fromY = 90 + Math.random() * 140;
        const toX = 380 + (Math.random() - 0.5) * 100;
        const toY = 130 + (Math.random() - 0.5) * 60;
        
        const p = createParticle(fromX, fromY, '#7c3aed');
        p.targetX = toX;
        p.targetY = toY;
        p.delay = i * 0.05;
        p.started = false;
        p.progress = 0;
        p.done = false;
        particles.push(p);
      }

      // Animar partículas
      let particleProgress = 0;
      function animateParticles() {
        if (currentPhase !== 2) { animating = false; return; }
        particleProgress += 0.03;
        
        let allDone = true;
        particles.forEach(p => {
          if (!p.started) {
            if (particleProgress > p.delay) p.started = true;
            else { allDone = false; return; }
          }
          if (!p.done) {
            p.progress += 0.05;
            if (p.progress >= 1) { p.progress = 1; p.done = true; }
            const ease = 1 - Math.pow(1 - p.progress, 3);
            const x = p.x + (p.targetX - p.x) * ease;
            const y = p.y + (p.targetY - p.y) * ease;
            p.element.setAttribute('transform', `translate(${x}, ${y})`);
            allDone = false;
          }
        });

        if (particleProgress < 1) {
          requestAnimationFrame(animateParticles);
        } else {
          // Partículas llegaron -> mostrar token
          setTimeout(() => {
            // Mostrar el token
            generatedText += token;
            outputToken.textContent = generatedText.substring('La capital de Francia es'.length);
            
            // Destello en VRAM
            document.querySelectorAll('.vram-chip').forEach(chip => {
              chip.setAttribute('opacity', '0.95');
              setTimeout(() => chip.setAttribute('opacity', '0.6'), 400);
            });

            // Actualizar contadores
            totalData.textContent = Math.round(accumulatedData) + ' GB';
            tokenCount.textContent = tokenNum + 1;
            
            infoLine1.textContent = `✅ "${token.trim()}" generado — ${Math.round(readPerToken)} GB leídos`;
            
            // Destacar el dato clave
            if (tokenNum === 1) {
              infoLine2.textContent = '⚠️ Los pesos NO han cambiado. Se han vuelto a leer.';
              infoLine3.textContent = 'El modelo no recuerda nada entre tokens.';
            } else if (tokenNum === TOKENS.length) {
              infoLine2.textContent = `📊 Total: ${Math.round(accumulatedData)} GB transferidos desde VRAM`;
              infoLine3.textContent = '💡 Los pesos siguen siendo los mismos 14 GB originales';
            } else {
              infoLine2.textContent = `📊 Acumulado: ${Math.round(accumulatedData)} GB desde VRAM`;
              infoLine3.textContent = '🔁 Y seguirá leyéndolos para cada nuevo token';
            }

            // Limpiar partículas
            clearParticles();
            
            // Siguiente token
            setTimeout(() => {
              tokenIdx++;
              generateNext();
            }, 1200);
          }, 300);
        }
      }

      requestAnimationFrame(animateParticles);
    }

    generateNext();
  }

  function resetAll() {
    if (animationId) cancelAnimationFrame(animationId);
    animating = false;
    clearParticles();
    setPhase(0);
    playBtn.textContent = '▶️ Iniciar animación';
    playBtn.dataset.nextPhase = '0';
    playBtn.onclick = startAnimation;
    resetBtn.onclick = resetAll;
    // Reset progress
    progressFill.style.width = '0%';
    progressPct.textContent = '0%';
    outputToken.textContent = '';
    document.getElementById('input-prompt').textContent = '';
    tokenCursor.style.display = 'inline';
    vramStatus.textContent = 'Esperando...';
    totalData.textContent = '0 GB';
    tokenCount.textContent = '0';
    phaseExplanation.innerHTML = PHASE_EXPLANATIONS[0];
    textOutput.classList.add('hidden');
    progressContainer.classList.add('hidden');
    document.querySelectorAll('.vram-chip').forEach(chip => {
      chip.setAttribute('fill', '#7c3aed');
      chip.setAttribute('opacity', '0.5');
    });
    textBox.setAttribute('opacity', '0');
  }

  function startAnimation() {
    if (animating) return;
    
    switch (currentPhase) {
      case 0:
        animatePhase1();
        break;
      case 1:
        animatePhase2();
        break;
      case 2:
        animatePhase3();
        break;
    }
  }

  // Event listeners
  phaseBtns.forEach((btn, i) => {
    btn.addEventListener('click', function() {
      if (animating) {
        if (animationId) cancelAnimationFrame(animationId);
        animating = false;
      }
      setPhase(i);
      playBtn.textContent = i === 0 ? '▶️ Iniciar animación' : '▶️ Empezar fase';
      playBtn.onclick = startAnimation;
    });
  });

  playBtn.onclick = startAnimation;
  resetBtn.onclick = resetAll;

  // Auto-start phase 1 on first load? No, wait for user.
})();
</script>
