---
// LevelTabs.astro — Tabs interactivos con JS vanilla
// Reemplaza al componente Vue que no funciona con slots nombrados en Astro islands

const { defaultTab = 'beginner' } = Astro.props

const tabs = [
  { id: 'beginner', label: '🟢 Para empezar' },
  { id: 'deep', label: '🟡 A fondo' },
  { id: 'advanced', label: '🔬 Avanzado' },
]
---

<div class="level-tabs mb-6" data-default={defaultTab}>
  <div class="flex gap-1 border-b border-neutral-200 mb-4" role="tablist">
    {tabs.map((tab) => (
      <button
        class="tab-btn px-4 py-2 text-sm font-medium transition-colors rounded-t-lg border-b-2 -mb-px data-[active=true]:border-current data-[active=true]:bg-neutral-50 data-[active=false]:text-neutral-500 data-[active=false]:hover:text-neutral-700 data-[active=false]:border-transparent"
        data-tab={tab.id}
        data-active={tab.id === defaultTab}
        role="tab"
        aria-selected={tab.id === defaultTab}
      >
        {tab.label}
      </button>
    ))}
  </div>

  <div class="tab-content" data-level="beginner" data-active={defaultTab === 'beginner'}>
    <slot name="beginner" />
  </div>
  <div class="tab-content" data-level="deep" data-active={defaultTab === 'deep'}>
    <slot name="deep" />
  </div>
  <div class="tab-content" data-level="advanced" data-active={defaultTab === 'advanced'}>
    <slot name="advanced" />
  </div>
</div>

<style>
  .tab-content[data-active="false"] { display: none; }
  .tab-content[data-active="true"] { display: block; }
</style>

<script>
  (function() {
    document.querySelectorAll('.level-tabs').forEach(function(el) {
      var buttons = el.querySelectorAll('.tab-btn');
      var contents = el.querySelectorAll('.tab-content');

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var tabId = btn.getAttribute('data-tab');

          // Update buttons
          buttons.forEach(function(b) {
            b.setAttribute('data-active', b.getAttribute('data-tab') === tabId);
            b.setAttribute('aria-selected', String(b.getAttribute('data-tab') === tabId));
          });

          // Update contents
          contents.forEach(function(c) {
            c.setAttribute('data-active', c.getAttribute('data-level') === tabId);
          });
        });
      });
    });
  })();
</script>
