---
import DocLayout from '../layouts/DocLayout.astro'
import { getAllEntries, CATEGORY_INFO } from '../data/ia-salud'
import { SITE } from '../consts'
import fs from 'fs'
import path from 'path'

const allEntries = getAllEntries()
const categories = [...new Set(allEntries.flatMap(e => e.articles.map(a => a.category)))]

// Leer borradores pendientes
const pendingDir = path.resolve(process.cwd(), 'ia-salud/pending')
let pendingCount = 0
try {
  if (fs.existsSync(pendingDir)) {
    pendingCount = fs.readdirSync(pendingDir).filter(f => f.endsWith('.md')).length
  }
} catch { /* no pending dir */ }
---

<DocLayout
  title="IA Generativa en Salud"
  description="Selección semanal de artículos científicos sobre inteligencia artificial generativa aplicada a la salud. Curados por endocrino, para clínicos."
  currentPath="/ia-salud"
  :sections={[
    { id: 'archivo', label: '📚 Archivo de entradas', level: 'beginner' },
    ...categories.map(c => ({
      id: `cat-${c}`,
      label: `${CATEGORY_INFO[c]?.emoji || '📄'} ${CATEGORY_INFO[c]?.label || c}`,
      level: 'beginner' as const
    })),
    ...(pendingCount > 0 ? [{ id: 'borradores', label: '📝 Borradores', level: 'beginner' as const }] : []),
  ]}
>
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-neutral-900 mb-2">🏥 IA Generativa en Salud</h1>
    <p class="text-lg text-neutral-600 mb-4">
      Artículos científicos seleccionados cada semana sobre aplicaciones clínicas de la IA generativa.
      Curados por <strong>Hermes</strong> 🤖 — el asistente de <strong>{SITE.author}</strong>, desde PubMed con sesgo endocrinológico declarado.
    </p>
    <div class="flex flex-wrap gap-4 text-sm">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-neutral-100 rounded-lg text-neutral-600">
        <span class="font-semibold text-neutral-800">{allEntries.length}</span> entradas publicadas
      </span>
      {pendingCount > 0 && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-50 border border-amber-200 rounded-lg text-amber-700">
          <span class="font-semibold">{pendingCount}</span> borrador{pendingCount > 1 ? 'es' : ''} pendiente{pendingCount > 1 ? 's' : ''}
        </span>
      )}
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-neutral-100 rounded-lg text-neutral-600">
        <span class="font-semibold text-neutral-800">{categories.length}</span> especialidades
      </span>
    </div>
  </div>

  <!-- Timeline de entradas -->
  <section id="archivo" class="content-section">
    {allEntries.length === 0 ? (
      <div class="p-8 text-center text-neutral-400 border-2 border-dashed border-neutral-200 rounded-2xl">
        <p class="text-4xl mb-3">📭</p>
        <p class="text-sm font-medium">No hay entradas publicadas aún</p>
        <p class="text-xs mt-1">El sistema está configurado. Cada domingo llegarán nuevos artículos.</p>
      </div>
    ) : (
      <div class="space-y-3">
        {allEntries.map((entry, i) => (
          <a
            href={`/ia-salud/${entry.slug}`}
            class="block group p-4 sm:p-5 bg-white border border-neutral-200 rounded-xl hover:border-primary-200 hover:shadow-md transition-all"
          >
            <div class="flex items-start gap-4">
              <!-- Fecha vertical -->
              <div class="hidden sm:flex flex-col items-center w-12 pt-0.5 shrink-0">
                <span class="text-xs font-semibold text-neutral-400 uppercase">
                  {entry.date ? new Date(entry.date + 'T00:00:00').toLocaleDateString('es', { month: 'short' }) : ''}
                </span>
                <span class="text-lg font-bold text-neutral-600 -mt-0.5">
                  {entry.date ? new Date(entry.date + 'T00:00:00').getDate() : ''}
                </span>
                {i < allEntries.length - 1 && (
                  <div class="w-px flex-1 bg-neutral-200 mt-2 min-h-[24px]"></div>
                )}
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                  <span class="text-xs text-neutral-400 sm:hidden">{entry.date}</span>
                  {entry.readingTime && <span class="text-xs text-neutral-400">{entry.readingTime}</span>}
                  <span class="text-xs text-neutral-300">·</span>
                  <span class="text-xs text-neutral-500">{entry.articles.length} artículo{entry.articles.length !== 1 ? 's' : ''}</span>
                </div>
                <h3 class="text-base font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors">
                  {entry.title}
                </h3>
                {entry.summary && (
                  <p class="mt-1 text-sm text-neutral-600 line-clamp-2">{entry.summary}</p>
                )}
                <!-- Mini badges de categorías -->
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {[...new Set(entry.articles.map(a => a.category))].slice(0, 3).map(cat => {
                    const info = CATEGORY_INFO[cat]
                    return info ? (
                      <span class={`text-xs px-2 py-0.5 rounded-full ${info.color}`}>
                        {info.emoji} {info.label}
                      </span>
                    ) : null
                  })}
                  {entry.tags.length > 0 && entry.tags.slice(0, 2).map(tag => (
                    <span class="text-xs px-2 py-0.5 bg-neutral-100 text-neutral-400 rounded-full">#{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <!-- Por categoría -->
  {categories.map(cat => {
    const info = CATEGORY_INFO[cat]
    const catEntries = allEntries.filter(e => e.articles.some(a => a.category === cat))
    if (catEntries.length === 0) return null
    return (
      <section id={`cat-${cat}`} class="content-section">
        <h2 class="text-xl font-bold text-neutral-900 mb-4">
          {info?.emoji || '📄'} {info?.label || cat}
        </h2>
        <ul class="list-disc list-inside space-y-1 text-sm text-neutral-700">
          {catEntries.slice(0, 5).map(entry => (
            <li>
              <a href={`/ia-salud/${entry.slug}`} class="text-primary-600 hover:text-primary-700 underline underline-offset-2">
                {entry.title}
              </a>
              <span class="text-neutral-400 ml-1">— {entry.date}</span>
            </li>
          ))}
        </ul>
      </section>
    )
  })}
</DocLayout>
