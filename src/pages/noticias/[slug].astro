---
import DocLayout from '../../layouts/DocLayout.astro'
import { getNewsBySlug, CATEGORY_EMOJIS, resolveWikilinks } from '../../data/news'
import type { NewsItem } from '../../data/news'
import { marked } from 'marked'

// Configurar marked
marked.use({ gfm: true })

export async function getStaticPaths() {
  const { getAllNews } = await import('../../data/news')
  const allNews = getAllNews()
  return allNews.map((news) => ({
    params: { slug: news.slug },
    props: { news },
  }))
}

const { news } = Astro.props as { news: NewsItem }
---

<DocLayout
  title={news.title}
  description={news.summary}
  currentPath={`/noticias/${news.slug}`}
  :sections={[
    { id: 'noticia', label: news.title, level: 'beginner' },
  ]}
>
  <article class="max-w-3xl">
    <!-- Header de la noticia -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs px-2.5 py-1 rounded-full font-medium"
          class:list={{
            'bg-purple-100 text-purple-700': news.category === 'modelos',
            'bg-amber-100 text-amber-700': news.category === 'hardware',
            'bg-blue-100 text-blue-700': news.category === 'investigación',
            'bg-green-100 text-green-700': news.category === 'industria',
            'bg-neutral-100 text-neutral-700': !['modelos','hardware','investigación','industria'].includes(news.category),
          }}
        >
          {CATEGORY_EMOJIS[news.category] || '📄'} {news.category}
        </span>
        <span class="text-sm text-neutral-400">{news.date}</span>
        {news.reading_time && <span class="text-sm text-neutral-300">·</span>}
        {news.reading_time && <span class="text-sm text-neutral-400">{news.reading_time} de lectura</span>}
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold text-neutral-900 leading-tight">
        {news.title}
      </h1>

      {news.summary && (
        <p class="mt-3 text-lg text-neutral-600 leading-relaxed">
          {news.summary}
        </p>
      )}

      <div class="flex items-center gap-2 mt-4 text-sm text-neutral-400">
        <span>Fuente:</span>
        {news.sourceUrl ? (
          <a href={news.sourceUrl} target="_blank" rel="noopener noreferrer"
            class="text-primary-600 hover:text-primary-700 underline underline-offset-2">
            {news.source} ↗
          </a>
        ) : (
          <span class="text-neutral-500">{news.source}</span>
        )}
      </div>

      {news.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {news.tags.map(tag => (
            <span class="px-2 py-0.5 bg-neutral-100 text-neutral-500 rounded text-xs">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Cuerpo de la noticia (markdown + wikilinks renderizados) -->
    <div class="prose prose-neutral max-w-none markdown-content" set:html={marked.parse(resolveWikilinks(news.content))} />

    <!-- Footer de navegación -->
    <div class="mt-12 pt-6 border-t border-neutral-200">
      <a href="/noticias" class="inline-flex items-center gap-2 text-sm text-primary-600 hover:text-primary-700 font-medium">
        ← Volver al archivo de noticias
      </a>
    </div>
  </article>
</DocLayout>
